# ==============================================================
# HƯỚNG DẪN:
# 1. Copy file này và đổi tên thành "application.properties"
# 2. Điền thông tin thật của bạn (Database password, JWT Secret)
# 3. Chạy dự án
# ==============================================================

spring.application.name=discord-backend
server.port=8085

# --- CẤU HÌNH MYSQL ---
# Nếu bạn dùng Docker hoặc Server riêng, hãy sửa 'localhost' thành IP tương ứng
spring.datasource.url=jdbc:mysql://localhost:3306/discord_clone?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
# 👇 ĐIỀN MẬT KHẨU MYSQL CỦA BẠN VÀO ĐÂY 👇
spring.datasource.password=YOUR_MYSQL_PASSWORD_HERE
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# --- CẤU HÌNH JPA / HIBERNATE ---
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect

# --- CẤU HÌNH MONGODB ---
# Cấu trúc: mongodb://[username:password@]host:port/database
spring.data.mongodb.uri=mongodb://localhost:27017/discord_chat_db

# --- CẤU HÌNH BẢO MẬT (JWT) ---
# 👇 TỰ TẠO MỘT CHUỖI BÍ MẬT DÀI VÀ NGẪU NHIÊN 👇
app.jwt-secret=YOUR_SUPER_SECRET_KEY_DO_NOT_SHARE
app.jwt-expiration-milliseconds=604800000